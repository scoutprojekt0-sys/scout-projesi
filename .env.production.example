APP_NAME="Scout API"
APP_ENV=production
APP_KEY=base64:replace-with-generated-key
APP_DEBUG=false
APP_URL=https://api.example.com
AUTH_REQUIRE_EMAIL_VERIFICATION=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=scout_api
DB_USERNAME=scout_user
DB_PASSWORD=replace-with-strong-password

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.example.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=replace-with-redis-password
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=replace-with-mail-password
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

STRIPE_KEY=pk_live_replace_me
STRIPE_SECRET=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

IYZICO_API_KEY=replace-me
IYZICO_SECRET_KEY=replace-me
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_CALLBACK_URL=https://api.example.com/api/webhooks/iyzico
IYZICO_DEFAULT_IDENTITY_NUMBER=

PAYPAL_CLIENT_ID=replace-me
PAYPAL_SECRET=replace-me
PAYPAL_MODE=live
PAYPAL_WEBHOOK_SECRET=replace-me

FRONTEND_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
SANCTUM_TOKEN_EXPIRATION=10080
LOG_SECURITY_LEVEL=info
LOG_SECURITY_DAYS=30
LOG_OPS_LEVEL=info
LOG_OPS_DAYS=14
MONITOR_SLOW_REQUEST_MS=800
OPPORTUNITIES_CACHE_ENABLED=true
OPPORTUNITIES_CACHE_TTL_SECONDS=60
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_API_READ_PER_MINUTE=120
RATE_LIMIT_API_WRITE_PER_MINUTE=40
AUTH_FAILED_ATTEMPTS_BEFORE_LOCK=5
AUTH_LOCK_SECONDS=900
