            <div class="sidebar-section">
                <div class="sidebar-title">ДҹЕёвҖңЕ  Verilerim</div>
                <ul class="sidebar-menu">
                    <li class="sidebar-item">
                        <span class="sidebar-item-icon">ДҹЕёвҖңЛҶ</span>
                        <span>Г„В°statistikler</span>
                    </li>
                    <li class="sidebar-item">
                        <span class="sidebar-item-icon">ДҹЕёВҸвҖ </span>
                        <span>BaГ…ЕёarГ„ВұlarГ„Вұm</span>
                    </li>
                </ul>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-title">ГўЕЎв„ўГҜВёВҸ Ayarlar</div>
                <ul class="sidebar-menu">
                    <li class="sidebar-item">
                        <span class="sidebar-item-icon">ГўЕЎв„ўГҜВёВҸ</span>
                        <span>Ayarlar</span>
                    </li>
                    <li class="sidebar-item">
                        <span class="sidebar-item-icon">ГўВқвҖң</span>
                        <span>YardГ„Вұm</span>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- CONTENT -->
        <div class="content">
            <!-- WELCOME CARD -->
            <div class="welcome-card">
                <div class="welcome-left">
                    <h1>Merhaba, Ahmet Demir! ДҹЕёвҖҳвҖ№</h1>
                    <div class="welcome-info">
                        <div class="info-item">ГўЕЎВҪ Spor: <strong>Futbol</strong></div>
                        <div class="info-item">ДҹЕёвҖңВҚ Pozisyon: <strong>Forvet</strong></div>
                        <div class="info-item">ДҹЕёвҖҳВӨ YaГ…Её: <strong>24</strong> | ДҹЕёвҖңВҸ Boy: <strong>180cm</strong></div>
                    </div>
                    <div class="welcome-buttons">
                        <button class="btn btn-primary" onclick="window.location.href='profile-edit.html'">Profili DГғВјzenle</button>
                        <button class="btn btn-secondary" onclick="alert('BaГ„ЕёlantГ„Вұ kopyalandГ„Вұ!')">BaГ„ЕёlantГ„ВұyГ„Вұ Kopyala</button>
                    </div>
