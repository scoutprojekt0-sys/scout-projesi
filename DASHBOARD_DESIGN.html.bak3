    <!-- PROFIL DГғЕ“ZENLEME MODAL KALDIRГ„ВұLDГ„Вұ - profile-edit.html'e taГ…ЕёГ„ВұndГ„Вұ -->

    <script>
        function logout() {
            localStorage.removeItem('nextscout_token');
            localStorage.removeItem('nextscout_user_email');
            localStorage.removeItem('nextscout_user_name');
            localStorage.removeItem('nextscout_user_role');
            localStorage.removeItem('nextscout_user_id');
            window.location.href = 'index.html';
        }
        
        // ...existing code...
        function openProfileEdit() {
            document.getElementById('profileEditModal').style.display = 'flex';
        }

        function closeProfileEditModal() {
            document.getElementById('profileEditModal').style.display = 'none';
        }

        // DГ„ВұГ…Еёa tГ„ВұklanГ„Вұnca kapat
        document.getElementById('profileEditModal').addEventListener('click', (e) => {
            if (e.target.id === 'profileEditModal') {
                closeProfileEditModal();
            }
        });

        // Sayfa yГғВјklenirken profil verilerini dashboard'ta gГғВ¶ster
        window.addEventListener('load', () => {
            const savedProfile = localStorage.getItem('playerProfile');
            const savedPhoto = localStorage.getItem('playerPhoto');

            if (savedProfile) {
                const data = JSON.parse(savedProfile);

                // KartГ„Вұn pozisyon bilgisini gГғВјncelle
                const positionElement = document.querySelector('.player-position');
                if (positionElement) {
                    positionElement.textContent = data.position.toUpperCase();
                }

                // Г„В°statistikleri gГғВјncelle (KartГ„Вұn iГғВ§inde)
                const stats = document.querySelectorAll('.stat-item');
                if (stats[0]) stats[0].querySelector('.stat-value').textContent = data.age;
                if (stats[1]) stats[1].querySelector('.stat-value').textContent = data.height + 'cm';
                if (stats[2]) stats[2].querySelector('.stat-value').textContent = data.matches;
                if (stats[3]) stats[3].querySelector('.stat-value').textContent = data.goals;
                if (stats[4]) stats[4].querySelector('.stat-value').textContent = data.assists;
                if (stats[5]) stats[5].querySelector('.stat-value').textContent = data.rating;

                // Rating gГғВјncelle
                const ratingText = document.querySelector('.rating-text');
                if (ratingText) {
                    ratingText.textContent = data.rating + '/10 Rating';
                }
            }

            // FotoГ„ЕёrafГ„Вұ gГғВјncelle
            if (savedPhoto) {
                const profileImage = document.querySelector('.profile-image');
                if (profileImage) {
                    profileImage.textContent = '';
                    const img = document.createElement('img');
                    img.src = savedPhoto;
                    img.style.width = '100%';
                    img.style.height = '100%';
                    img.style.borderRadius = '50%';
                    img.style.objectFit = 'cover';
                    profileImage.appendChild(img);
                }
            }

            // Modal form verilerini yГғВјkle
            const savedProfileData = localStorage.getItem('playerProfile');
            if (savedProfileData) {
                const data = JSON.parse(savedProfileData);
                document.getElementById('positionSelect').value = data.position;
                document.getElementById('ageInput').value = data.age;
                document.getElementById('heightInput').value = data.height;
                document.getElementById('matchesInput').value = data.matches;
                document.getElementById('goalsInput').value = data.goals;
                document.getElementById('assistsInput').value = data.assists;
                document.getElementById('ratingInput').value = data.rating;
                document.getElementById('bioInput').value = data.bio;
                document.getElementById('videoUrl').value = data.videoUrl;
            }

            const savedPhotoData = localStorage.getItem('playerPhoto');
            if (savedPhotoData) {
                const img = document.getElementById('photoImg');
                if (img) {
                    img.src = savedPhotoData;
                    img.style.display = 'block';
                }
            }
        });
        // ...existing code...
    </script>
</body>
</html>

