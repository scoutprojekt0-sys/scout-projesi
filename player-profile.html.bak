    <script>
        // localStorage'dan profil verilerini yÃ¼kle ve gÃ¶ster
        function loadProfileData() {
            const savedProfile = localStorage.getItem('playerProfile');
            const savedPhoto = localStorage.getItem('playerPhoto');

            console.log('Saved Profile:', savedProfile);
            console.log('Saved Photo:', savedPhoto);

            if (savedProfile) {
                try {
                    const data = JSON.parse(savedProfile);
                    
                    // Pozisyon
                    const posElement = document.getElementById('playerPosition');
                    if (posElement) posElement.textContent = (data.position || 'Forvet').toUpperCase();
                    
                    // YaÅŸ
                    const ageElement = document.getElementById('playerAge');
                    if (ageElement) ageElement.textContent = data.age || '24';
                    
                    // Boy
                    const heightElement = document.getElementById('playerHeight');
                    if (heightElement) heightElement.textContent = (data.height || '180') + 'cm';
                    
                    // Rating
                    const ratingElement = document.getElementById('playerRating');
                    if (ratingElement) ratingElement.textContent = data.rating || '4.8';
                    
                    const ratingTextElement = document.getElementById('ratingText');
                    if (ratingTextElement) ratingTextElement.textContent = (data.rating || '4.8') + '/10 - Scoutlar TarafÄ±ndan DeÄŸerlendirildi';
                    
                    // Bio
                    const bioElement = document.getElementById('bioText');
                    if (bioElement) bioElement.textContent = data.bio || 'TÃ¼rkiye\'nin en yetenekli forvet oyuncularÄ±ndan biri. GÃ¼Ã§lÃ¼ fizik yapÄ±sÄ±, hÄ±zÄ± ve gol yeteneÄŸi ile biliniyor.';
                    
                    // Ä°statistikler
                    const matchesElement = document.getElementById('statMatches');
                    if (matchesElement) matchesElement.textContent = data.matches || '28';
                    
                    const goalsElement = document.getElementById('statGoals');
                    if (goalsElement) goalsElement.textContent = data.goals || '15';
                    
                    const assistsElement = document.getElementById('statAssists');
                    if (assistsElement) assistsElement.textContent = data.assists || '6';
                    
                    console.log('Profile data loaded successfully');
                } catch (e) {
                    console.error('Error parsing profile data:', e);
                }
            }

            // FotoÄŸrafÄ± gÃ¼ncelle
            if (savedPhoto) {
                const heroImage = document.getElementById('heroImage');
                if (heroImage) {
                    heroImage.textContent = '';
                    const img = document.createElement('img');
                    img.src = savedPhoto;
                    img.style.width = '100%';
                    img.style.height = '100%';
                    img.style.objectFit = 'cover';
                    img.style.borderRadius = '16px';
                    heroImage.appendChild(img);
                    console.log('Photo loaded');
                }
            }
        }

        // Sayfa yÃ¼klendiÄŸinde Ã§alÄ±ÅŸtÄ±r
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', loadProfileData);
        } else {
            loadProfileData();
        }

        function logoutFromProfile() {
            localStorage.removeItem('nextscout_token');
            localStorage.removeItem('nextscout_user');
            localStorage.removeItem('nextscout_demo_login');
            window.location.href = 'index.html';
        }

        // Her saniye kontrol et (real-time gÃ¼ncelleme)
        setInterval(loadProfileData, 1000);
    </script>
</body>
</html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Oyuncu Profili | NextScout</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #1f2937;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        .back-btn {
            display: inline-block;
            margin-bottom: 20px;
            padding: 10px 16px;
            background: rgba(255, 255, 255, 0.2);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .back-btn:hover {
            background: rgba(255, 255, 255, 0.3);
        }

        .profile-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
        }

        .profile-image-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .profile-image-section::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            top: -50px;
            right: -50px;
        }

        .profile-image {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            border: 4px solid white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 80px;
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }

        .status-badge {
            display: inline-block;
            background: #52e0c1;
            color: white;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            margin-top: 10px;
        }

        .profile-info-section {
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .player-name {
            font-size: 32px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 5px;
            letter-spacing: -0.5px;
        }

        .player-position {
            font-size: 16px;
            color: #667eea;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
        }

        .divider {
            width: 60px;
            height: 3px;
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            margin-bottom: 20px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 25px;
        }

        .stat-item {
            background: #f9fafb;
            padding: 15px;
            border-radius: 12px;
            border-left: 4px solid #667eea;
        }

        .stat-label {
            font-size: 12px;
            color: #9ca3af;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 5px;
            letter-spacing: 0.5px;
        }

        .stat-value {
            font-size: 24px;
            font-weight: 800;
            color: #1f2937;
        }

        .actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 20px;
        }

        .btn {
            padding: 12px 16px;
            border: none;
            border-radius: 10px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-secondary {
            background: #f3f4f6;
            color: #667eea;
            border: 2px solid #667eea;
        }

        .btn-secondary:hover {
            background: #667eea;
            color: white;
        }

        .rating-section {
            background: #fff9e6;
            padding: 15px;
            border-radius: 12px;
            border: 2px solid #fbbf24;
            margin-top: 15px;
            text-align: center;
        }

        .rating-stars {
            font-size: 24px;
            color: #fbbf24;
            margin-bottom: 5px;
        }

        .rating-text {
            font-size: 13px;
            font-weight: 600;
            color: #1f2937;
        }

        @media (max-width: 768px) {
            .profile-card {
                grid-template-columns: 1fr;
            }

            .profile-info-section {
                padding: 30px 20px;
            }

            .player-name {
                font-size: 24px;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .actions {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="DASHBOARD_DESIGN.html" class="back-btn">â† Geri DÃ¶n</a>

        <div class="profile-card">
