    <script>
        // Profil bilgilerini localStorage'dan yÃ¼kle
        window.addEventListener('load', () => {
            const savedProfile = localStorage.getItem('playerProfile');
            const savedPhoto = localStorage.getItem('playerPhoto');

            if (savedProfile) {
                const data = JSON.parse(savedProfile);

                // Pozisyon gÃ¼ncelle
                document.querySelector('.player-position').textContent = data.position.toUpperCase();

                // Ä°statistikleri gÃ¼ncelle
                document.querySelectorAll('.stat-value')[0].textContent = data.age;
                document.querySelectorAll('.stat-value')[1].textContent = data.height + 'cm';
                document.querySelectorAll('.stat-value')[2].textContent = data.matches;
                document.querySelectorAll('.stat-value')[3].textContent = data.goals;
                document.querySelectorAll('.stat-value')[4].textContent = data.assists;
                document.querySelectorAll('.stat-value')[5].textContent = data.rating;

                // Rating gÃ¼ncelle
                document.querySelector('.rating-text').textContent = data.rating + '/10 - Scoutlar TarafÄ±ndan DeÄŸerlendirildi';

                // Biyografi gÃ¼ncelle
                const bioElements = document.querySelectorAll('p');
                for (let i = 0; i < bioElements.length; i++) {
                    if (bioElements[i].textContent.includes("TÃ¼rkiye'nin")) {
                        bioElements[i].textContent = data.bio;
                        break;
                    }
                }

                // Video URL'i gÃ¼ncelle
                if (data.videoUrl) {
                    document.querySelector('[style*="Video"]').innerHTML = `
                        <p style="font-size: 18px; margin: 0; color: white;">ğŸ¥ Video Portfolio</p>
                        <p style="font-size: 12px; color: #9ca3af; margin-top: 10px;"><a href="${data.videoUrl}" target="_blank" style="color: #6cc6ff;">Video linki aÃ§ â†’</a></p>
                    `;
                }
            }

            // FotoÄŸrafÄ± gÃ¼ncelle
            if (savedPhoto) {
                document.querySelector('.profile-image').textContent = '';
                const img = document.createElement('img');
                img.src = savedPhoto;
                img.style.width = '100%';
                img.style.height = '100%';
                img.style.borderRadius = '50%';
                img.style.objectFit = 'cover';
                document.querySelector('.profile-image').appendChild(img);
            }
        });
    </script>
