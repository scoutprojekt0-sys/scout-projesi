            <!-- Ä°LETÄ°ÅÄ°M -->
            <div class="card">
                <h3 class="card-title">ğŸ“§ Ä°letiÅŸim</h3>
                <div class="stats-list">
                    <button class="btn btn-primary" style="width: 100%; margin-bottom: 10px;">ğŸ’¬ Mesaj GÃ¶nder</button>
                    <button class="btn btn-secondary" style="width: 100%;">â˜ï¸ AracÄ± Ara</button>
                </div>
