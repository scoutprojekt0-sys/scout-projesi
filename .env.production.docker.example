APP_NAME="Scout API"
APP_ENV=production
APP_KEY=base64:replace-with-generated-key
APP_DEBUG=false
APP_URL=https://api.nextscout.pro
APP_TIMEZONE=Europe/Istanbul

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=scout_api
DB_USERNAME=scout_user
DB_PASSWORD=replace-with-strong-password
DB_ROOT_PASSWORD=replace-with-strong-root-password

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.nextscout.pro
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=nextscout.pro,www.nextscout.pro

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=replace-with-redis-password
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=replace-with-mail-password
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_BASE_URL=https://api.brevo.com/v3
BREVO_SENDER_EMAIL="${MAIL_FROM_ADDRESS}"
BREVO_SENDER_NAME="${MAIL_FROM_NAME}"

FRONTEND_URL=https://nextscout.pro
CORS_ALLOWED_ORIGINS=https://nextscout.pro,https://www.nextscout.pro
SANCTUM_TOKEN_EXPIRATION=10080
LOG_SECURITY_LEVEL=info
LOG_SECURITY_DAYS=30
LOG_OPS_LEVEL=info
LOG_OPS_DAYS=14
MONITOR_SLOW_REQUEST_MS=800
OPPORTUNITIES_CACHE_ENABLED=true
OPPORTUNITIES_CACHE_TTL_SECONDS=60
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_API_READ_PER_MINUTE=120
RATE_LIMIT_API_WRITE_PER_MINUTE=40
AUTH_FAILED_ATTEMPTS_BEFORE_LOCK=5
AUTH_LOCK_SECONDS=900
AI_ANALYSIS_MODE=external
AI_ANALYSIS_WORKER_BASE_URL=http://ai-worker:8010
AI_ANALYSIS_CALLBACK_SECRET=change-me-production-required
AI_ANALYSIS_WORKER_TIMEOUT_SECONDS=60
AI_ANALYSIS_ALLOW_MOCK_FALLBACK=false

AI_WORKER_PORT=8010
AI_WORKER_MODE=pipeline
AI_WORKER_DETECTOR=auto
AI_WORKER_YOLO_MODEL_PATH=yolov8n.pt
AI_WORKER_FOOTBALL_MODEL_PATH=models/football_player_ball.pt
AI_WORKER_BASKETBALL_MODEL_PATH=models/basketball_player_ball.pt
AI_WORKER_VOLLEYBALL_MODEL_PATH=models/volleyball_player_ball.pt
AI_WORKER_SAMPLE_EVERY_SECONDS=1
AI_WORKER_MAX_SAMPLE_SECONDS=300
AI_WORKER_DOWNLOAD_TIMEOUT_SECONDS=60
AI_WORKER_CALLBACK_TIMEOUT_SECONDS=20
AI_WORKER_LOG_LEVEL=info
